ENVIRONMENT=development
API_PREFIX=/api
FRONTEND_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://memorymesh:memorymesh@localhost:5432/memorymesh_dev
SIGNING_SECRET=replace-with-a-secure-secret

# Prize path: Best Use of Cognee Cloud
# Calls cognee.serve(), then remember/recall/improve/forget route to Cognee Cloud.
MEMORYMESH_MEMORY_BACKEND=cognee_cloud
COGNEE_ENABLED=true
COGNEE_SERVICE_URL=https://your-tenant.cognee.ai
COGNEE_API_KEY=your-cognee-cloud-api-key
COGNEE_DEFAULT_DATASET=memorymesh-agent-work-memory
COGNEE_ALLOW_OFFLINE_FALLBACK=true

# LLM routing used by agent reasoning and Cognee-compatible local development.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AIMLAPI_API_KEY=
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
AIMLAPI_MODEL=gpt-4o-mini
LLM_PRIMARY_PROVIDER=openai
LLM_FALLBACK_PROVIDER=aimlapi
AUTH_REQUIRED=false
