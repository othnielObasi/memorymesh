ENVIRONMENT=production
API_PREFIX=
FRONTEND_ORIGIN=https://your-memorymesh-app.vercel.app
SIGNING_SECRET=replace-with-a-secure-secret

# Use a managed PostgreSQL service for production.
DATABASE_URL=postgresql://user:password@host:5432/memorymesh
MEMORYMESH_DEV_INMEMORY_STORE=false

# Cloud memory mode. Add COGNEE_SERVICE_URL when Cognee gives you the service URL.
MEMORYMESH_MEMORY_BACKEND=auto
COGNEE_ENABLED=true
COGNEE_API_KEY=your-cognee-api-key
COGNEE_SERVICE_URL=
COGNEE_DEFAULT_DATASET=memorymesh-agent-work-memory
COGNEE_ALLOW_OFFLINE_FALLBACK=true

# Production must not read arbitrary local machine paths.
MEMORYMESH_ALLOW_ANY_LOCAL_PROJECT=false
MEMORYMESH_LOCAL_PROJECT_ROOTS=

# LLM routing.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
AIMLAPI_API_KEY=
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
AIMLAPI_MODEL=gpt-4o-mini
LLM_PRIMARY_PROVIDER=openai
LLM_FALLBACK_PROVIDER=aimlapi

AUTH_REQUIRED=true
