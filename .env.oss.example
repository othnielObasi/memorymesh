ENVIRONMENT=development
API_PREFIX=/api
FRONTEND_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://memorymesh:memorymesh@localhost:5432/memorymesh_dev
SIGNING_SECRET=replace-with-a-secure-secret

# Prize path: Best Use of Open Source
# Production local mode should point MemoryMesh at a self-hosted Cognee HTTP service.
# If this URL is blank, MemoryMesh tries the optional in-process Cognee SDK when installed.
MEMORYMESH_MEMORY_BACKEND=local_cognee
COGNEE_ENABLED=true
# Docker Compose API container -> Cognee running on host machine.
# Use http://127.0.0.1:8001 only when running the API directly outside Docker.
# Use http://cognee:8000 if you add Cognee as a service on the same Docker network.
COGNEE_LOCAL_SERVICE_URL=http://host.docker.internal:8001
COGNEE_LOCAL_API_KEY=
COGNEE_DEFAULT_DATASET=memorymesh-agent-work-memory
COGNEE_ALLOW_OFFLINE_FALLBACK=true

# Local project connection
# Set true for a trusted self-hosted/local install where users may point MemoryMesh at any folder.
# For shared servers, prefer MEMORYMESH_LOCAL_PROJECT_ROOTS with OS path separators.
MEMORYMESH_ALLOW_ANY_LOCAL_PROJECT=true
MEMORYMESH_LOCAL_PROJECT_ROOTS=

# Configure the LLM/embedding provider Cognee needs in your local environment.
# Example: OPENAI_API_KEY=sk-...
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AIMLAPI_API_KEY=
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
AIMLAPI_MODEL=gpt-4o-mini
LLM_PRIMARY_PROVIDER=openai
LLM_FALLBACK_PROVIDER=aimlapi
EMBEDDING_PROVIDER=hash
AUTH_REQUIRED=false
