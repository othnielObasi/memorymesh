ENVIRONMENT=development
API_PREFIX=/api
FRONTEND_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://memorymesh:memorymesh@localhost:5432/memorymesh_dev
DATABASE_POOL_MIN_SIZE=1
DATABASE_POOL_MAX_SIZE=10
DATABASE_COMMAND_TIMEOUT_SECONDS=30
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174"]

# Cognee memory layer for the hackathon demo
# auto | local_cognee | cognee_cloud | offline_mirror
MEMORYMESH_MEMORY_BACKEND=auto
COGNEE_ENABLED=false
COGNEE_SERVICE_URL=
COGNEE_API_KEY=
COGNEE_LOCAL_SERVICE_URL=
COGNEE_LOCAL_API_KEY=
COGNEE_DEFAULT_DATASET=memorymesh-agent-work-memory
COGNEE_ALLOW_OFFLINE_FALLBACK=true
MEMORYMESH_ALLOW_ANY_LOCAL_PROJECT=false
MEMORYMESH_LOCAL_PROJECT_ROOTS=

# Local/demo embeddings
EMBEDDING_PROVIDER=hash
EMBEDDING_DIMENSIONS=384
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ANTHROPIC_API_KEY=
AIMLAPI_API_KEY=
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
AIMLAPI_MODEL=gpt-4o-mini
LLM_PRIMARY_PROVIDER=openai
LLM_FALLBACK_PROVIDER=aimlapi
LLM_TIMEOUT_SECONDS=45

# Optional model/tool integrations. Not required for the Cognee demo.
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
TRUEFOUNDRY_BASE_URL=
TRUEFOUNDRY_API_KEY=
TRUEFOUNDRY_MODEL=
TRUEFOUNDRY_FALLBACK_MODEL=
TRUEFOUNDRY_MCP_GATEWAY_URL=
TRUEFOUNDRY_MCP_API_KEY=
GOOGLE_GEMINI_API_KEY=
GOOGLE_VERTEX_PROJECT=

# Enterprise controls
AUTH_REQUIRED=false
SIGNING_SECRET=replace-with-a-secure-secret
BOOTSTRAP_ADMIN_TOKEN=replace-in-production
DEFAULT_ORGANISATION_ID=org_default
DEFAULT_WORKSPACE_ID=wrk_default
DEFAULT_PROJECT_ID=prj_default
DEFAULT_ENVIRONMENT_ID=dev
DEFAULT_MODEL_GATEWAY=local
AUDIT_LOG_RETENTION_DAYS=365
RUN_RETENTION_DAYS=365
ENABLE_OPEN_TELEMETRY=false
OTEL_SERVICE_NAME=memorymesh-api
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_LEASE_SECONDS=300
